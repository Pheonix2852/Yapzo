{
  "expo": {
    "name": "Yapzo",
    "slug": "Yapzo",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "yapzo",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "com.sagnik.yapzo",
      "supportsTablet": true
    },
    "android": {
      "package": "com.sagnik.yapzo",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.BLUETOOTH",
        "android.permission.BLUETOOTH_CONNECT",
        "android.permission.BLUETOOTH_ADMIN",
        "android.permission.WAKE_LOCK"
      ]
    },
    "web": {
      "output": "server",
      "favicon": "./assets/images/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "cameraPermission": "$(PRODUCT_NAME) would like to use your camera to share image in message",
          "photoLibraryPermission": "$(PRODUCT_NAME) would like to access your photo library to share image in message"
        }
      ],
      [
        "expo-audio",
        {
          "microphonePermission": "$(PRODUCT_NAME) would like to access your microphone to share audio in message"
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 24
          }
        }
      ],
      [
        "expo-font",
        {
          "fonts": [
            "./assets/fonts/GoogleSans-Regular.ttf",
            "./assets/fonts/GoogleSans-Bold.ttf",
            "./assets/fonts/GoogleSans-Medium.ttf"
          ]
        }
      ],
      "@clerk/expo",
      "expo-secure-store",
      "expo-web-browser",
      [
        "@sentry/react-native/expo",
        {
          "url": "https://sentry.io/",
          "project": "yapzo",
          "organization": "sagnik-9z"
        }
      ],
      "expo-audio",
      [
        "@stream-io/video-react-native-sdk",
        [
          "@config-plugins/react-native-webrtc",
          {
            "cameraPermission": "$(PRODUCT_NAME) requires camera access in order to capture and transmit video",
            "microphonePermission": "$(PRODUCT_NAME) requires microphone access in order to capture and transmit audio"
          }
        ]
      ],
      "expo-asset"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "7463879e-0eb7-40fc-bdbf-efa6d24cb3cc"
      }
    }
  }
}
